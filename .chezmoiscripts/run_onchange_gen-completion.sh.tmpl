#!/usr/bin/env bash

# hash: {{ include "dot_config/mise/config.toml" | sha256sum }}
# hash: {{ include ".chezmoitemplates/Brewfile.tmpl" | sha256sum }}

# TODO: Support nu
dest="${HOME}/.zsh/fpath"
_SH='zsh'

test -d "${dest}" || mkdir -p "${dest}"

function tc() {
    command -v "$1" &> /dev/null
}

function gen() {
    if ! tc "${1}"; then
        return
    fi

    echo "Generating completion for '${1}'"
    "$@" > "${dest}/_${1}.zsh"
}

gen task --completion "${_SH}"
gen xh --generate complete-"${_SH}"
gen ripgrep --generate complete-"${_SH}"
gen atuin gen-completions --shell "${_SH}"
gen doggo completions "${_SH}"
gen rclone completion "${_SH}" -

for tool in \
    "chezmoi" \
    "cosign" \
    "docker" \
    "limactl" \
    "mise" \
    "op" \
    "sops" \
    "step" \
    "usql" \
    "yq"; do
    gen "${tool}" completion "${_SH}"
done
